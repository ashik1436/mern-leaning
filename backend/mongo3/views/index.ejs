<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Whatsapp</title>
    <link rel="stylesheet" href="style.css"/>
</head>
<body>
    <h3>
        all chats
    </h3>
    
<% for (let chat of chats){ %>
    <div class="chat">
        <p>from : <%= chat.from %></p>
        <div class="msg">
             <p><%= chat.msg %></p>

        </div>
        <p>received by  <%= chat.to%></p>
        <hr/>
    </div>
    <br/>
    <br/>
<% } %>
    
</body>
</html>
